# Backstep configuration
# Copy this file to .env and fill in your values

# Anthropic API key — required for running agents
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Database path — where Backstep stores session data
# Default (if unset): ~/.backstep/backstep.db
# Override example:   BACKSTEP_DB=./my_project.db
# BACKSTEP_DB=

# API port — port the FastAPI backend listens on
# Default: 7842
BACKSTEP_API_PORT=7842

# Frontend API URL — what the Vue app uses to reach the backend
# In Docker: http://backend:7842
# In local dev: http://localhost:7842
VITE_API_URL=http://localhost:7842
